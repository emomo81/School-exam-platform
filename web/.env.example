# Frontend env (safe for the browser only where NEXT_PUBLIC_*).
# Copy to web/.env.local and fill in. NEVER put the Supabase service-role key here.

# Supabase — anon key only (RLS-scoped, read-only Realtime per PRD §8.1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Render API base URL (all writes/auth go through here)
NEXT_PUBLIC_API_URL=http://localhost:8080
