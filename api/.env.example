# Render API env — SERVER-ONLY secrets. Never commit real values; never expose to the browser.
# Copy to api/.env and fill in.

PORT=8080
NODE_ENV=development

# Supabase — service role key bypasses RLS and is used for all writes (PRD §8.1).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Must equal the Supabase project's JWT secret so Supabase verifies the
# student tokens Render mints (AUTH-SPEC §2/§3).
SUPABASE_JWT_SECRET=
