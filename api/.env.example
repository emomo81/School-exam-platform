# Render API env — SERVER-ONLY secrets. Never commit real values; never expose to the browser.
# Copy to api/.env and fill in.

PORT=8080
NODE_ENV=development

# Direct Postgres connection string.
# Supabase dashboard → Project Settings → Database → Connection string (URI).
# Use the pooled "Session"/"Transaction" URI and include your DB password.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.cpxaxaogreaiajdytvlq.supabase.co:5432/postgres

# Must equal the Supabase project's JWT secret so Supabase Realtime verifies the
# student tokens Render mints (AUTH-SPEC §2/§3).
# Supabase dashboard → Project Settings → API → JWT Settings → JWT Secret.
SUPABASE_JWT_SECRET=

# Access-token lifetime in seconds (default 600 = 10 min).
ACCESS_TOKEN_TTL_SECONDS=600
